# ── NETAI Chatbot Environment Configuration ─────────────────────────
# Copy to .env and fill in values:  cp .env.example .env

# ── LLM Service ─────────────────────────────────────────────────────
# Option 1: OpenAI GPT-4o (recommended for demo)
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o

# Option 2: NRP Managed LLM Service (for deployment on NRP)
# LLM_API_BASE_URL=https://llm.nrp-nautilus.io/v1
# LLM_API_KEY=your-nrp-api-key
# LLM_MODEL=qwen3-vl

# Set to false to use a real LLM, true for offline mock mode
LLM_MOCK_MODE=true

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database
DATABASE_URL=sqlite:///data/netai_chatbot.db

# perfSONAR Integration
PERFSONAR_API_URL=https://ps-dashboard.nrp.ai/api
PERFSONAR_POLL_INTERVAL=300

# Kubernetes
K8S_NAMESPACE=netai
K8S_GPU_ENABLED=false
